# ===================================================================
#  Kathirha environment — copy to .env for docker-compose,
#  or use the PowerShell `$env:` commands in INTEGRATIONS.md for local runs.
#  Everything is OPTIONAL: with nothing set, the app runs on mocks + the
#  deterministic AI engine. Add a block to switch that integration to "real".
# ===================================================================

# ---- Core ----
DB_NAME=kathirha
DB_USERNAME=kathirha
DB_PASSWORD=kathirha
JWT_SECRET=change-me-to-a-long-random-32plus-byte-secret-value
BACKEND_PORT=8080
FRONTEND_PORT=8088
# Frontend origins allowed to call the API (add your ngrok URL when testing on a phone)
CORS_ORIGINS=http://localhost:8088,http://localhost:5173

# ---- AI: OpenAI (optional; deterministic engine is the fallback) ----
AI_PROVIDER=auto                 # auto | openai | deterministic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Open banking ----
# mock      = synthetic Saudi data (default, instant)
# gocardless = REAL self-serve sandbox (Nordigen). Get keys at https://bankaccountdata.gocardless.com
BANK_PROVIDER=mock
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
GOCARDLESS_COUNTRY=GB            # sandbox works under GB; use SANDBOXFINANCE_SFIN0000 bank
# Must equal your frontend origin + /bank/callback (localhost or your ngrok URL)
GOCARDLESS_REDIRECT_URL=http://localhost:5173/bank/callback

# ---- WhatsApp: Twilio (optional; mock simulator is the fallback) ----
# Get SID + token at https://console.twilio.com ; join the sandbox from your phone.
WHATSAPP_PROVIDER=mock           # mock | twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Set the Twilio sandbox "When a message comes in" webhook to:
#   https://<your-ngrok>/api/whatsapp/webhook

# ---- Email: Mailtrap (optional) ----
# Email Sandbox (captures mail in a test inbox): host sandbox.smtp.mailtrap.io, port 2525
# Live sending: host live.smtp.mailtrap.io, port 587, username "api", password = API token
EMAIL_ENABLED=false
MAIL_HOST=
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=Kathirha <no-reply@kathirha.app>
